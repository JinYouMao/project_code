<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.online.messageboard.mapper.AdminMapper">

    <!-- 结果映射：管理员实体 -->
    <resultMap id="adminResultMap" type="com.online.messageboard.entity.Admin">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
    </resultMap>

    <!-- 根据用户名和密码查询管理员 -->
    <select id="selectByUsernameAndPassword" resultMap="adminResultMap">
        SELECT * FROM admin WHERE username = #{username} AND password = #{password}
    </select>

    <!-- 根据用户名查询管理员 -->
    <select id="selectByUsername" resultMap="adminResultMap">
        SELECT * FROM admin WHERE username = #{username}
    </select>
</mapper>
