<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.online.messageboard.mapper.ReplyMapper">

    <!-- 基础结果映射 -->
    <resultMap id="BaseResultMap" type="com.online.messageboard.entity.Reply">
        <id column="id" property="id"/>
        <result column="message_id" property="messageId"/>
        <result column="reply_content" property="replyContent"/>
        <result column="reply_time" property="replyTime"/>
        <result column="admin_name" property="adminName"/>
    </resultMap>

    <!-- 插入回复 -->
    <insert id="insert" parameterType="com.online.messageboard.entity.Reply" 
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO reply (message_id, reply_content, reply_time, admin_name)
        VALUES (
            #{messageId},
            #{replyContent},
            #{replyTime},
            #{adminName}
        )
    </insert>

    <!-- 根据ID删除回复 -->
    <delete id="deleteById">
        DELETE FROM reply WHERE id = #{id}
    </delete>

    <!-- 根据留言ID删除回复 -->
    <delete id="deleteByMessageId">
        DELETE FROM reply WHERE message_id = #{messageId}
    </delete>

    <!-- 更新回复 -->
    <update id="update" parameterType="com.online.messageboard.entity.Reply">
        UPDATE reply
        SET reply_content = #{replyContent},
            reply_time = #{replyTime},
            admin_name = #{adminName}
        WHERE id = #{id}
    </update>

    <!-- 根据ID查询回复 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM reply WHERE id = #{id}
    </select>

    <!-- 根据留言ID查询回复 -->
    <select id="selectByMessageId" resultMap="BaseResultMap">
        SELECT * FROM reply WHERE message_id = #{messageId}
    </select>

    <!-- 查询所有回复 -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM reply ORDER BY reply_time DESC
    </select>

</mapper>
